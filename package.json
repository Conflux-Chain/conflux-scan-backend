{
  "name": "conflux-stat",
  "version": "0.0.7",
  "description": "conflux-statistics",
  "main": "index.js",
  "scripts": {
    "test": "test",
    "compile": "npx tsc -p ./stat/tsconfig.json",
    "api-c": "npx tsc -b ./open-api",
    "copyfiles": "cp ./stat/service/watcher/contract/*.json ./stat/dist/service/watcher/contract/",
    "api:dev": "tsc-watch -b ./open-api --onSuccess 'node --inspect=0.0.0.0:5858 ./open-api/ApiServer.js'",
    "start:dev": "tsc-watch -p ./stat --onSuccess 'node --inspect=0.0.0.0:5858 ./stat/dist/Index.js'",
    "start:dev2": "tsc-watch -p ./stat",
    "start:tools": "tsc-watch -b ./tools --onSuccess 'node ./stat/dist/test/Dev.js'"
  },
  "dependencies": {
    "@conflux-dev/conflux-address-rust": "0.1.6",
    "@koa/cors": "~3.1.0",
    "@types/koa-bodyparser": "~4.3.0",
    "agentkeepalive": "^4.1.4",
    "ali-oss": "~6.16.0",
    "bigfixed": "0.0.2",
    "express-to-koa": "~2.0.0",
    "influx": "~5.9.3",
    "js-conflux-sdk": "2.0.0-beta.15",
    "koa": "2.13.1",
    "koa-bodyparser": "~4.3.0",
    "koa-helmet": "6.0.0",
    "koa-router": "~10.0.0",
    "koa-static": "5.0.0",
    "koa2-swagger-ui": "5.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.29.1",
    "mysql2": "^2.2.5",
    "node-cache": "5.1.2",
    "p-limit": "2.3.0",
    "pino": "^6.10.0",
    "prom-client": "~13.0.0",
    "ratelimiter": "~3.4.1",
    "redis": "^3.1.2",
    "request-ip": "^2.1.3",
    "sequelize": "~6.6.5",
    "superagent": "5.1.0",
    "swagger-stats": "~0.99.2",
    "web3": "^1.6.1",
    "winston": "3.3.3",
    "winston-daily-rotate-file": "4.5.5",
    "yamljs": "0.3.0",
    "@conflux-lib/cbor": "1.0.4",
    "@conflux-lib/kvstore": "3.6.2",
    "@conflux-lib/logger": "1.1.0",
    "superagent-proxy": "2.1.0",
    "cbor": "5.1.0",
    "semver": "7.3.2",
    "solc": "0.8.6",
    "koaflow": "0.6.4",
    "limit-map": "0.0.2",
    "prome-string": "0.0.8",
    "csv-stringify": "5.5.3",
    "fast-diff": "1.2.0"
  },
  "devDependencies": {
    "@types/ali-oss": "6.0.10",
    "@types/redis": "^2.8.28",
    "typescript": "4.1.3",
    "@types/lodash": "4.14.176",
    "tsc-watch": "~4.2.9",
    "@types/koa": "2.11.6",
    "@types/koa-helmet": "6.0.1",
    "@types/koa-router": "7.4.1"
  },
  "repository": {
