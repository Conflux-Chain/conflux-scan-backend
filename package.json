{
  "name": "conflux-stat",
  "version": "0.0.7",
  "description": "conflux-statistics",
  "main": "index.js",
  "scripts": {
    "test": "test",
    "compile": "npx tsc -b ./scan-api ./open-api",
    "api-c": "npx tsc -b ./open-api",
    "api-clean": "npx tsc -b --clean ./open-api",
    "copyfiles": "cp ./stat/service/watcher/contract/*.json ./stat/service/watcher/contract/",
    "api:dev": "tsc-watch -b ./open-api --onSuccess 'node --inspect=0.0.0.0:5858 ./open-api/ApiServer.js'",
    "start:dev": "tsc-watch -p ./stat --onSuccess 'node --inspect=0.0.0.0:5858 ./stat/dist/Index.js'",
    "start:dev2": "tsc-watch -p ./stat",
    "start:tools": "tsc-watch -b ./tools --onSuccess 'node ./stat/dist/test/Dev.js'",
    "sdk-core": "rm -rf ./document/openapi-sdk-core-ts/ | openapi-generator-cli generate -i ./document/open-api.yaml -g typescript-axios -o ./document/openapi-sdk-core-ts/ --skip-validate-spec --additional-properties=npmName=@conflux-lib/openapi-sdk-core,npmVersion=1.0.0,npmRepository=https://registry.npmjs.org/,supportsES6=true",
    "sdk-evm": "rm -rf ./document/openapi-sdk-evm-ts/ | openapi-generator-cli generate -i ./document/espace-open-api.yaml -g typescript-axios -o ./document/openapi-sdk-evm-ts/ --skip-validate-spec --additional-properties=npmName=@conflux-lib/openapi-sdk-evm,npmVersion=1.0.0,npmRepository=https://registry.npmjs.org/,supportsES6=true",
    "sdk-core-doc": "openapi-generator-cli generate -i ./document/open-api.yaml -g markdown -o ./document/openapi-sdk-core-ts/ --skip-validate-spec",
    "sdk-evm-doc": "openapi-generator-cli generate -i ./document/espace-open-api.yaml -g markdown -o ./document/openapi-sdk-evm-ts/ --skip-validate-spec"
  },
  "dependencies": {
    "@conflux-dev/conflux-address-rust": "0.1.6",
    "@conflux-lib/cbor": "1.0.4",
    "@conflux-lib/kvstore": "3.6.2",
    "@confluxfans/nft-utils": "^1.0.4",
    "@koa/cors": "~3.1.0",
    "@types/koa-bodyparser": "~4.3.0",
    "@web3identity/address-encoder": "^0.2.20",
    "agentkeepalive": "^4.1.4",
    "ali-oss": "~6.16.0",
    "baidu-aip-sdk": "^4.16.10",
    "big.js": "^6.2.1",
    "bigfixed": "0.0.2",
    "cbor": "5.1.0",
    "csv-stringify": "5.5.3",
    "ethers": "^5.6.9",
    "express-to-koa": "~2.0.0",
    "fast-diff": "1.2.0",
    "graphql": "^16.6.0",
    "graphql-request": "^5.0.0",
    "influx": "~5.9.3",
    "inspector-influx": "^2.10.0",
    "inspector-metrics": "^1.23.0",
    "js-conflux-sdk": "^2.1.10",
    "koa": "2.13.1",
    "koa-bodyparser": "~4.3.0",
    "koa-helmet": "6.0.0",
    "koa-proxy": "1.0.0-alpha.3",
    "koa-router": "~10.0.0",
    "koa-static": "5.0.0",
    "koa2-swagger-ui": "5.0.5",
    "koaflow": "0.6.4",
    "limit-map": "0.0.2",
    "lodash": "^4.17.21",
    "lru-cache": "^7.13.1",
    "moment": "^2.29.1",
    "mysql2": "^2.2.5",
    "node-abort-controller": "^3.0.1",
    "node-cache": "5.1.2",
    "node-docker-api": "^1.1.22",
    "p-limit": "2.3.0",
    "ping": "^0.4.2",
    "pino": "^6.10.0",
    "prom-client": "~13.0.0",
    "prome-string": "0.0.8",
    "rate-limiter-flexible": "2.3.7",
    "ratelimiter": "~3.4.1",
    "redis": "^3.1.2",
    "request-ip": "^2.1.3",
    "semver": "7.3.2",
    "sequelize": "~6.35.2",
    "solc": "0.8.6",
    "superagent": "5.1.0",
    "superagent-proxy": "2.1.0",
    "swagger-stats": "~0.99.2",
    "web3pay-sdk-js": "^0.0.11",
    "winston": "3.3.3",
    "winston-daily-rotate-file": "4.5.5",
    "xlsx": "^0.18.5",
