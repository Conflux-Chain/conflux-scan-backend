    "bigfixed": "0.0.2",
    "js-conflux-sdk": "1.6.9",
    "koa": "^2.13.1",
    "koa-bodyparser": "^4.3.0",
    "koa-helmet": "6.0.0",
    "koa-router": "^10.0.0",
    "koa-static": "5.0.0",
    "koa2-swagger-ui": "^5.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.29.1",
    "mysql2": "^2.2.5",
    "node-cache": "5.1.2",
    "pino": "^6.10.0",
    "redis": "^3.1.2",
    "sequelize": "^6.3.5",
    "superagent": "5.1.0"
  },
