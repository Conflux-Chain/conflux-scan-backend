{
  "name": "conflux-stat",
  "version": "0.0.7",
  "description": "conflux-statistics",
  "main": "index.js",
  "scripts": {
    "test": "test",
    "compile": "npx tsc -p ./stat",
    "copyfiles": "cp ./stat/service/watcher/contract/*.json ./stat/dist/service/watcher/contract/",
    "start:dev": "tsc-watch -p ./stat --onSuccess 'node --inspect=0.0.0.0:5858 ./stat/dist/Index.js'",
    "start:tools": "tsc-watch -b ./tools --onSuccess 'node ./stat/dist/test/Dev.js'"
  },
  "dependencies": {
    "@koa/cors": "^3.1.0",
    "@types/koa-bodyparser": "^4.3.0",
    "agentkeepalive": "^4.1.4",
