{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "commonjs", // ensure using `require` instead of `import`
    "downlevelIteration": true,
    "target": "ES2016",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "experimentalDecorators": true
  }
}
