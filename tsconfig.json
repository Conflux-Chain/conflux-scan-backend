{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "commonjs", // ensure using `require` instead of `import`
    "downlevelIteration": true,
    "target": "ES2020",
    "lib": ["ES2020", "ES2015.Collection"], // ,"es2015.collection", "es5", "dom","es2015.iterable"
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "experimentalDecorators": true
  }
}
